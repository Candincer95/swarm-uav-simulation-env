        </visual>
      </link>
      <joint name="fixed_to_ground" type="fixed">
        <parent>world</parent>
        <child>pole</child>
      </joint>
      <link name="fabric">
        <pose>0.75 0 3.8 0 0 0</pose>
        <enable_wind>true</enable_wind>
