    <model name="windsock_flag">
      <pose>6 0 0 0 0 0</pose>
      <link name="pole">
        <pose>0 0 2 0 0 0</pose>
        <inertial><mass>100</mass><inertia><ixx>1</ixx><iyy>1</iyy><izz>1</izz></inertia></inertial>
