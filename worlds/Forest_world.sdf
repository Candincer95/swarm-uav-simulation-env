      <visual name="vis">
        <geometry><box><size>1.5 0.02 0.6</size></box></geometry>
        <material><ambient>1.0 0.3 0.0 1</ambient><diffuse>1.0 0.3 0.0 1</diffuse></material>
      </visual>
      </link>
      <joint name="hinge" type="universal">
        <parent>pole</parent>
        <child>fabric</child>
        <pose>-0.75 0 0 0 0 0</pose>
        <axis><xyz>0 0 1</xyz></axis>
        <axis2><xyz>0 1 0</xyz></axis2>
      </joint>
    </model>

